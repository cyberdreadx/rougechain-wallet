{
    "manifest_version": 3,
    "name": "RougeChain Wallet",
    "version": "1.1.0",
    "description": "Quantum-safe cryptocurrency wallet & encrypted messenger for RougeChain",
    "homepage_url": "https://github.com/cyberdreadx/rougechain-wallet",
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16": "icons/icon-16.png",
            "48": "icons/icon-48.png",
            "128": "icons/icon-128.png"
        }
    },
    "icons": {
        "16": "icons/icon-16.png",
        "48": "icons/icon-48.png",
        "128": "icons/icon-128.png"
    },
    "permissions": [
        "storage",
        "alarms"
    ],
    "host_permissions": [
        "https://rougechain.io/*",
        "https://*.rougechain.io/*",
        "http://localhost/*"
    ],
    "background": {
        "service_worker": "service-worker.js",
        "type": "module"
    },
    "content_scripts": [
        {
            "matches": [
                "https://rougechain.io/*",
                "https://*.rougechain.io/*",
                "https://testnet.rougechain.io/*",
                "http://localhost/*"
            ],
            "js": [
                "content.js"
            ],
            "run_at": "document_start"
        }
    ],
    "web_accessible_resources": [
        {
            "resources": [
                "provider.js",
                "approval.html"
            ],
            "matches": [
                "https://rougechain.io/*",
                "https://*.rougechain.io/*",
                "https://testnet.rougechain.io/*",
                "http://localhost/*"
            ]
        }
    ],
    "content_security_policy": {
        "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
    }
}